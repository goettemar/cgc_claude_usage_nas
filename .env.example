# Claude.ai Session (required)
SESSION_KEY=sk-ant-sid...
ORG_UUID=

# Anthropic Admin API (optional)
ADMIN_API_KEY=

# OpenRouter (optional)
OPENROUTER_API_KEY=

# DeepL (optional)
DEEPL_API_KEY=

# App Settings
AUTO_REFRESH_MINUTES=15
RETENTION_DAYS=90

# Data directory (default: /app/data)
DATA_DIR=/app/data
